{
  "name": "@bettergov/kapwa",
  "private": false,
  "version": "1.2.4",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "concurrently -p \"[{name}]\" -n \"CLIENT,STORYBOOK\" -c \"bgBlue.bold,bgMagenta.bold\" \"npm run start:client\" \"npm run start:storybook\"",
    "start:client": "vite --config vite.config-site.ts --open",
    "start:storybook": "storybook dev --docs -p 6006",
    "build-lib": "vite build --config vite.config-lib.ts && node scripts/generate-component-exports.mjs",
    "build-site": "vite build --config vite.config-site.ts",
    "build": "npm run build-lib && npm run build-site && npm run build:storybook",
    "build:storybook": "storybook build -o ./site/storybook",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write .",
    "preview": "vite preview --config vite.config-site.ts",
    "prepare": "husky",
    "registry:build": "shadcn build",
    "semantic-release": "semantic-release",
    "local-registry:publish": "npm run build-lib && npm publish",
    "local-registry:unpublish": "npm unpublish @bettergov/kapwa --force"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.9.1",
    "@icons-pack/react-simple-icons": "^13.7.0",
    "@playwright/test": "^1.55.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@storybook/addon-a11y": "^9.1.8",
    "@storybook/addon-actions": "^9.0.8",
    "@storybook/addon-essentials": "^9.0.0-alpha.12",
    "@storybook/addon-interactions": "^9.0.0-alpha.10",
    "@storybook/addon-links": "^9.1.8",
    "@storybook/blocks": "^9.0.0-alpha.17",
    "@storybook/react": "^9.1.8",
    "@storybook/react-vite": "^9.1.7",
    "@tailwindcss/postcss": "^4.1.16",
    "@tailwindcss/vite": "^4.2.0",
    "@types/glob": "^8.1.0",
    "@types/node": "^24.5.2",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.9.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "glob": "^10.4.5",
    "globals": "^15.9.0",
    "husky": "^9.1.7",
    "i18next": "^25.5.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "lint-staged": "^16.1.6",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^15.7.3",
    "react-router-dom": "^7.13.1",
    "semantic-release": "^24.2.9",
    "shadcn": "^3.8.5",
    "storybook": "^9.1.7",
    "tailwindcss": "^4.2.0",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.20.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "vite-plugin-dts": "^4.5.4"
  },
  "peerDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "postcss": "^8.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "lucide-react": "^0.575.0",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.3.6"
  },
  "overrides": {
    "react-helmet-async": {
      "react": "^19.0.0",
      "react-dom": "^19.0.0"
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
