    },
    "./utils": {
      "types": "./dist/kapwa/utils/index.d.ts",
      "import": "./dist/kapwa/utils/index.ts.js",
      "require": "./dist/kapwa/utils/index.ts.cjs",
      "default": "./dist/kapwa/utils/index.ts.js"
    }
  },
  "typesVersions": {
    "*": {
      ".": [
        "./dist/index.d.ts"
      ],
      "article": [
        "./dist/kapwa/article/index.d.ts"
      ],
      "banner": [
        "./dist/kapwa/banner/index.d.ts"
      ],
      "button": [
        "./dist/kapwa/button/index.d.ts"
